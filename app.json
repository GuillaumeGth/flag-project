{
  "expo": {
    "name": "Flag",
    "slug": "flag-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "flag",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flagapp.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Flag utilise votre position pour afficher les messages autour de vous.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Flag utilise votre position en arrière-plan pour vous notifier quand vous êtes proche d'un message.",
        "NSCameraUsageDescription": "Flag utilise la caméra pour prendre des photos à joindre aux messages.",
        "NSMicrophoneUsageDescription": "Flag utilise le micro pour enregistrer des messages audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.flagapp.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "flag",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDrlGiPT_Wt94CvbjeHRn_CzKIp1Pw9OeY"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Flag utilise votre position pour vous notifier des messages proches.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#4A90D9"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Flag utilise la caméra pour les photos."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "c8cb48ce-1c64-4314-a6ad-ada1e82efca8"
      }
    },
    "owner": "guillaumed.gth"
  }
}
